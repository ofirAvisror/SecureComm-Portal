{
  "minLength": 10,
  "requireUppercase": true,
  "requireLowercase": true,
  "requireDigit": true,
  "requireSpecial": true,
  "blockCommonPasswords": true,
  "commonPasswordsFile": "common-passwords.txt",
  "history": {
    "enabled": true,
    "previousCount": 3
  },
  "lockout": {
    "enabled": true,
    "maxAttempts": 3,
    "lockMinutes": 15
  },
  "resetTokenExpiryMinutes": 30
}
